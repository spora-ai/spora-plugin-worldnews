{
  "name": "spora-ai/spora-plugin-worldnews",
  "description": "World News API headlines and search for Spora agents.",
  "type": "spora-plugin",
  "license": "MIT",
  "require": {
    "php": "^8.4.1",
    "spora-ai/spora-core": ">=0.3.0 <1.0.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-mockery": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Spora\\Plugins\\WorldNews\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Spora\\Plugins\\WorldNews\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "analyse": "phpstan analyse --no-progress",
    "lint": "php-cs-fixer fix --dry-run --diff --no-interaction"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "spora-ai/installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
